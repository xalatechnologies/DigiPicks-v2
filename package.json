{
  "name": "digipicks",
  "version": "0.1.0",
  "private": true,
  "description": "DigiPicks — Premium sports picks from verified creators",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:convex\" \"pnpm dev:web\" \"pnpm dev:dashboard\"",
    "dev:web": "pnpm --filter @digipicks/web dev",
    "dev:dashboard": "pnpm --filter @digipicks/dashboard dev",
    "dev:api": "pnpm --filter @digipicks/api dev",
    "dev:convex": "npx convex dev",
    "dev:all": "concurrently \"pnpm dev:convex\" \"pnpm dev:web\" \"pnpm dev:dashboard\" \"pnpm dev:api\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "concurrently": "^9.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "convex": "^1.31.7"
  }
}
