# Copy to `.env.local` for local dev. On Vercel, set these in Project → Settings → Environment Variables.

# Required for the web app (production Convex HTTPS URL, e.g. https://happy-animal-123.convex.cloud)
VITE_CONVEX_URL=

# Optional
# VITE_SENTRY_DSN=
# VITE_RELEASE=

# QA only — optional `/dashboard` RBAC bypass (local dev OR hosted preview with both vars).
# Do not enable on customer-facing production.
# VITE_SHOW_DEMO_AUTH=true
# VITE_DEV_UNLOCK_DASHBOARD=true
# Optional: one-click "Open creator studio (dev)" on /apply (skips /auth; signs in as this user).
# VITE_DEV_CREATOR_EMAIL=wahid@xala.no
# VITE_DEV_CREATOR_PASSWORD=your-dev-password
