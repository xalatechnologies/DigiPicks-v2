# Copy to `.env.local` for local dev. On Vercel, set these in Project → Settings → Environment Variables.

# Convex CLI — copy to repo-root `.env.local` (from `npx convex dev`)
# CONVEX_DEPLOYMENT=dev:your-deployment
# CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_SITE_URL=https://your-deployment.convex.site

# Web app — copy to `apps/web/.env.local` (do not duplicate VITE_* in root `.env.local`)
VITE_CONVEX_URL=

# Convex Auth (JWT_PRIVATE_KEY, JWKS, SITE_URL) — set ON THE DEPLOYMENT, not in .env files:
#   pnpm setup:convex-auth
# Requires the same deployment as CONVEX_URL above.

# Optional
# VITE_SENTRY_DSN=
# VITE_RELEASE=

# QA only — optional `/dashboard` RBAC bypass (local dev OR hosted preview with both vars).
# Do not enable on customer-facing production.
# VITE_SHOW_DEMO_AUTH=true
# VITE_DEV_UNLOCK_DASHBOARD=true
# Optional: dev creator credentials for studio preview / auth flows in QA.
# VITE_DEV_CREATOR_EMAIL=wahid@xala.no
# VITE_DEV_CREATOR_PASSWORD=your-dev-password

# Optional: override dev admin auto sign-in at /admin (local pnpm dev uses defaults below).
# VITE_DEV_ADMIN_EMAIL=admin@digipicks.com
# VITE_DEV_ADMIN_PASSWORD=AdminDev123!
# Convex (server, optional): npx convex env set DEV_ADMIN_EMAIL admin@digipicks.com
# Convex (server, optional): npx convex env set DEV_ADMIN_PASSWORD AdminDev123!
